APP_ENV=local
APP_NAME=aiops-platform
APP_VERSION=0.1.0
APP_TIMEZONE=Asia/Seoul

POSTGRES_DB=kkpp
POSTGRES_USER=kkpp
POSTGRES_PASSWORD=kkpp
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kkpp:kkpp@localhost:5432/kkpp

LLM_PROVIDER=fake
LLM_MODEL=fake-agentic-planner
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_REQUIRE_API_KEY=true
# OpenAI 사용 예시:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=replace-with-openai-api-key
# Groq 사용 예시:
# LLM_PROVIDER=groq
# LLM_MODEL=qwen/qwen3-32b
# LLM_API_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_xxxx
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.1

PROMETHEUS_BASE_URL=http://localhost:9090
PROMETHEUS_SOURCE_URLS=
PROMETHEUS_TIMEOUT_SECONDS=10
LOKI_BASE_URL=http://localhost:3100
LOKI_SOURCE_URLS=
LOKI_TIMEOUT_SECONDS=10
KUBERNETES_API_BASE_URL=http://localhost:8001
KUBERNETES_BEARER_TOKEN=
KUBERNETES_BEARER_TOKEN_FILE=
KUBERNETES_CA_CERT_FILE=
KUBERNETES_NAMESPACE_ALLOWLIST=default,kube-system
KUBERNETES_TIMEOUT_SECONDS=10
ONPREM_KUBERNETES_API_BASE_URL=
ONPREM_KUBERNETES_BEARER_TOKEN=
ONPREM_KUBERNETES_CA_CERT=
ONPREM_KUBERNETES_NAMESPACE_ALLOWLIST=default,kkpp,monitoring,keda,postgres-ha,ingress-nginx
KAFKA_ADMIN_BASE_URL=http://localhost:8080
KAFKA_TIMEOUT_SECONDS=10
INFRAOPS_KAFKA_ENABLED=true
BATCH_API_BASE_URL=http://localhost:8081
BATCH_TIMEOUT_SECONDS=10
INFRAOPS_BATCH_ENABLED=true
ELASTICSEARCH_BASE_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_ALLOWLIST=logs-*,filebeat-*,metricbeat-*
ELASTICSEARCH_TIMEOUT_SECONDS=10
KIBANA_BASE_URL=http://localhost:5601
INFRAOPS_ELK_ENABLED=true
TOPOLOGY_KNOWLEDGE_DIRS=runtime_knowledge,docs
TOPOLOGY_KNOWLEDGE_S3_URI=
RCA_DEFAULT_BEFORE_MINUTES=10
RCA_DEFAULT_AFTER_MINUTES=5
RCA_JOB_RUNNER_ENABLED=false
RCA_JOB_RUNNER_IMAGE=
RCA_JOB_RUNNER_NAMESPACE=default
RCA_JOB_RUNNER_SERVICE_NAME=mcp-aiops-backend
RCA_JOB_RUNNER_LIMIT=20
RCA_JOB_RUNNER_TTL_SECONDS_AFTER_FINISHED=600
RCA_JOB_RUNNER_ACTIVE_DEADLINE_BUFFER_SECONDS=300

EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=aiops@example.com
SMTP_USE_TLS=true
OPS_REPORT_EMAIL_RECIPIENTS=
RCA_EMAIL_RECIPIENTS=

# EKS/production example values. Keep real secrets in Kubernetes Secret or GitHub Secrets.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@your-rds-endpoint.ap-northeast-2.rds.amazonaws.com:5432/kkpp
# PROMETHEUS_BASE_URL=http://10.30.2.103:9090
# PROMETHEUS_SOURCE_URLS=onprem=http://10.30.2.103:9090
# LOKI_BASE_URL=http://loki.monitoring.svc.cluster.local:3100
# LOKI_SOURCE_URLS=eks=http://loki.monitoring.svc.cluster.local:3100
# KUBERNETES_API_BASE_URL=https://kubernetes.default.svc
# KUBERNETES_BEARER_TOKEN_FILE=/var/run/secrets/kubernetes.io/serviceaccount/token
# KUBERNETES_CA_CERT_FILE=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt
# KUBERNETES_NAMESPACE_ALLOWLIST=default,kube-system,aiops,monitoring
