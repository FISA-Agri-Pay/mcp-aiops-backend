APP_ENV=local
APP_NAME=aiops-platform
APP_VERSION=0.1.0
APP_TIMEZONE=Asia/Seoul

POSTGRES_DB=kkpp
POSTGRES_USER=kkpp
POSTGRES_PASSWORD=kkpp
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kkpp:kkpp@localhost:5432/kkpp

LLM_PROVIDER=fake
LLM_MODEL=fake-agentic-planner
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_REQUIRE_API_KEY=true
# Groq 사용 예시:
# LLM_PROVIDER=groq
# LLM_MODEL=qwen/qwen3-32b
# LLM_API_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_xxxx
LLM_MAX_TOKENS=800
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.1

PROMETHEUS_BASE_URL=http://localhost:9090
PROMETHEUS_SOURCE_URLS=
PROMETHEUS_TIMEOUT_SECONDS=10
LOKI_BASE_URL=http://localhost:3100
LOKI_SOURCE_URLS=
LOKI_TIMEOUT_SECONDS=10
KUBERNETES_API_BASE_URL=http://localhost:8001
KUBERNETES_BEARER_TOKEN=
KUBERNETES_NAMESPACE_ALLOWLIST=default,kube-system
KUBERNETES_TIMEOUT_SECONDS=10
KAFKA_ADMIN_BASE_URL=http://localhost:8080
KAFKA_TIMEOUT_SECONDS=10
BATCH_API_BASE_URL=http://localhost:8081
BATCH_TIMEOUT_SECONDS=10
ELASTICSEARCH_BASE_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_ALLOWLIST=logs-*,filebeat-*,metricbeat-*
ELASTICSEARCH_TIMEOUT_SECONDS=10
KIBANA_BASE_URL=http://localhost:5601

EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=aiops@example.com
SMTP_USE_TLS=true
OPS_REPORT_EMAIL_RECIPIENTS=
